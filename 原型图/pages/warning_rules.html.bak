      <div class="main-wrapper">
        <header class="topbar">
          <div class="topbar-left">
            <div class="topbar-title">预警规则管理</div>
            <div class="topbar-breadcrumb">首页 / 境外人员管理 / 预警规则管理</div>
          </div>
          <div class="topbar-right">
            <div class="topbar-btn" title="通知中心">🔔</div>
            <div class="topbar-btn" title="系统设置">⚙</div>
            <div class="shell-duty-chip">
              <span>在线 12 人</span>
            </div>
            <div class="user-card">
              <div class="user-avatar">管</div>
              <div class="user-info">
                <div class="user-name">管理员</div>
              </div>
            </div>
          </div>
        </header>

        <main class="content-area">
          <div class="filter-card">
            <div class="filter-row">
              <div class="filter-item wide">
                <label class="filter-label">规则名称</label>
                <input
                  type="text"
                  class="filter-input"
                  id="ruleNameInput"
                  placeholder="输入规则名称搜索"
                />
              </div>
              <div class="filter-item">
                <label class="filter-label">规则状态</label>
                <select class="filter-select" id="statusFilter">
                  <option value="">全部状态</option>
                  <option value="enabled">已启用</option>
                  <option value="disabled">已停用</option>
                </select>
              </div>
              <div class="filter-item">
                <label class="filter-label">预警等级</label>
                <select class="filter-select" id="levelFilter">
                  <option value="">全部等级</option>
                  <option value="high">高危</option>
                  <option value="medium">中危</option>
                  <option value="low">低危</option>
                </select>
              </div>
              <div class="filter-actions">
                <button class="btn btn-primary" onclick="searchRules()">
                  <i class="ri-search-line"></i>查询
                </button>
                <button class="btn btn-secondary" onclick="resetFilters()">
                  <i class="ri-refresh-line"></i>重置
                </button>
                <button class="btn btn-primary" onclick="openModal('add')">
                  <i class="ri-add-line"></i>新增规则
                </button>
              </div>
            </div>
          </div>

          <div class="table-card">
            <div class="table-header">
              <span class="table-title">规则列表</span>
              <span class="table-info" id="tableInfo">共 5 条记录</span>
            </div>
            <table class="data-table">
              <thead>
                <tr>
                  <th>规则编号</th>
                  <th>规则名称</th>
                  <th>预警类型</th>
                  <th>触发条件</th>
                  <th>预警等级</th>
                  <th>适用对象</th>
                  <th>状态</th>
                  <th>创建时间</th>
                  <th>操作</th>
                </tr>
              </thead>
              <tbody id="ruleTableBody"></tbody>
            </table>
            <div class="pagination">
              <span class="pagination-info" id="paginationInfo"
                >显示 1-5 条，共 5 条</span
              >
              <div class="pagination-controls">
                <button class="page-btn" disabled>
                  <i class="ri-arrow-left-s-line"></i>
                </button>
                <button class="page-btn active">1</button>
                <button class="page-btn" disabled>
                  <i class="ri-arrow-right-s-line"></i>
                </button>
              </div>
            </div>
          </div>
        </main>
      </div>
    </div>

    <div class="modal-overlay" id="ruleModal">
      <div class="modal">
        <div class="modal-header">
          <h3 class="modal-title" id="modalTitle">新增规则</h3>
          <button class="modal-close" onclick="closeModal()">
            <i class="ri-close-line"></i>
          </button>
        </div>
        <div class="modal-body">
          <form id="ruleForm">
            <div class="form-grid">
              <div class="form-field form-grid-full">
                <label class="form-label"
                  >规则名称<span class="required">*</span></label
                >
                <input
                  type="text"
                  class="form-input"
                  id="ruleName"
                  placeholder="请输入规则名称"
                  required
                />
              </div>
              <div class="form-field">
                <label class="form-label"
                  >预警类型<span class="required">*</span></label
                >
                <select class="form-select" id="alertType" required>
                  <option value="">请选择预警类型</option>
                  <option value="behavior">行为预警</option>
                  <option value="track">轨迹预警</option>
                  <option value="area">区域预警</option>
                </select>
              </div>
              <div class="form-field">
                <label class="form-label"
                  >预警等级<span class="required">*</span></label
                >
                <select class="form-select" id="alertLevel" required>
                  <option value="">请选择预警等级</option>
                  <option value="high">高危</option>
                  <option value="medium">中危</option>
                  <option value="low">低危</option>
                </select>
              </div>
              <div class="form-field">
                <label class="form-label"
                  >适用对象<span class="required">*</span></label
                >
                <select class="form-select" id="targetObject" required>
                  <option value="">请选择适用对象</option>
                  <option value="focus">重点关注人员</option>
                  <option value="foreign">外籍人员</option>
                  <option value="blacklist">黑名单人员</option>
                </select>
              </div>
              <div class="form-field">
                <label class="form-label"
                  >触发阈值<span class="required">*</span></label
                >
                <input
                  type="text"
                  class="form-input"
                  id="threshold"
                  placeholder="如：次数、时长、频次"
                  required
                />
              </div>
              <div class="form-field form-grid-full">
                <label class="form-label"
                  >触发条件描述<span class="required">*</span></label
                >
                <textarea
                  class="form-textarea"
                  id="triggerCondition"
                  placeholder="请描述触发预警的具体条件"
                  required
                ></textarea>
              </div>
              <div class="form-field">
                <label class="form-label"
                  >处置方式<span class="required">*</span></label
                >
                <select class="form-select" id="disposalMethod" required>
                  <option value="">请选择处置方式</option>
                  <option value="remind">自动提醒</option>
                  <option value="push">推送值班人员</option>
                  <option value="ticket">生成预警工单</option>
                </select>
              </div>
              <div class="form-field">
                <label class="form-label">规则状态</label>
                <select class="form-select" id="ruleStatus">
                  <option value="enabled">启用</option>
                  <option value="disabled">停用</option>
                </select>
              </div>
              <div class="form-field form-grid-full">
                <label class="form-label">备注说明</label>
                <textarea
                  class="form-textarea"
                  id="remark"
                  placeholder="请输入备注信息"
                ></textarea>
              </div>
            </div>
          </form>
        </div>
        <div class="modal-footer">
          <button class="btn btn-secondary" onclick="closeModal()">取消</button>
          <button class="btn btn-primary" onclick="saveRule()">
            <i class="ri-save-line"></i>保存
          </button>
        </div>
      </div>
    </div>

    <script>
      const ruleData = [
        {
          id: "WR001",
          name: "重点人员夜间异常活动预警",
          type: "behavior",
          typeName: "行为预警",
          condition: "连续出现在多个敏感区域",
          level: "high",
          levelName: "高危",
          target: "focus",
          targetName: "重点关注人员",
          status: "enabled",
          createTime: "2026-04-10 09:30",
        },
        {
          id: "WR002",
          name: "外籍人员高频活动预警",
          type: "track",
          typeName: "轨迹预警",
          condition: "24小时内活动频次超过阈值",
          level: "medium",
          levelName: "中危",
          target: "foreign",
          targetName: "外籍人员",
          status: "enabled",
          createTime: "2026-04-08 14:20",
        },
        {
          id: "WR003",
          name: "黑名单人员区域闯入预警",
          type: "area",
          typeName: "区域预警",
          condition: "进入禁止区域范围",
          level: "high",
          levelName: "高危",
          target: "blacklist",
          targetName: "黑名单人员",
          status: "enabled",
          createTime: "2026-04-05 11:15",
        },
        {
          id: "WR004",
          name: "敏感时段活动异常预警",
          type: "behavior",
          typeName: "行为预警",
          condition: "夜间22:00-06:00高频活动",
          level: "low",
          levelName: "低危",
          target: "focus",
          targetName: "重点关注人员",
          status: "disabled",
          createTime: "2026-04-03 16:45",
        },
        {
          id: "WR005",
          name: "短时多次入境预警",
          type: "track",
          typeName: "轨迹预警",
          condition: "7天内入境超过5次",
          level: "medium",
          levelName: "中危",
          target: "foreign",
          targetName: "外籍人员",
          status: "enabled",
          createTime: "2026-04-01 10:00",
        },
      ];

      let currentEditId = null;

      function renderTable(data) {
        const tbody = document.getElementById("ruleTableBody");
        if (data.length === 0) {
          tbody.innerHTML = `
            <tr>
              <td colspan="9">
                <div class="empty-state">
                  <i class="ri-file-list-3-line"></i>
                  <p class="empty-state-text">暂无预警规则</p>
                </div>
              </td>
            </tr>
          `;
          return;
        }

        tbody.innerHTML = data
          .map(
            (rule) => `
          <tr>
            <td><span class="rule-id">${rule.id}</span></td>
            <td><span class="rule-name">${rule.name}</span></td>
            <td><span class="tag tag-primary">${rule.typeName}</span></td>
            <td>${rule.condition}</td>
            <td>
              <span class="tag ${
                rule.level === "high"
                  ? "tag-danger"
                  : rule.level === "medium"
                    ? "tag-warning"
                    : "tag-info"
              }">${rule.levelName}</span>
            </td>
            <td>${rule.targetName}</td>
            <td>
              <span class="tag ${rule.status === "enabled" ? "status-enabled" : "status-disabled"}">
                ${rule.status === "enabled" ? "启用" : "停用"}
              </span>
            </td>
            <td>${rule.createTime}</td>
            <td>
              <div class="action-btns">
                <button class="action-btn" title="查看" onclick="viewRule('${rule.id}')">
                  <i class="ri-eye-line"></i>
                </button>
                <button class="action-btn" title="编辑" onclick="editRule('${rule.id}')">
                  <i class="ri-edit-line"></i>
                </button>
                <button class="action-btn" title="${rule.status === "enabled" ? "停用" : "启用"}" onclick="toggleStatus('${rule.id}')">
                  <i class="ri-${rule.status === "enabled" ? "close" : "check"}-line"></i>
                </button>
                <button class="action-btn danger" title="删除" onclick="deleteRule('${rule.id}')">
                  <i class="ri-delete-bin-line"></i>
                </button>
              </div>
            </td>
          </tr>
        `,
          )
          .join("");

        document.getElementById("tableInfo").textContent =
          `共 ${data.length} 条记录`;
        document.getElementById("paginationInfo").textContent =
          `显示 1-${data.length} 条，共 ${data.length} 条`;
      }

      function searchRules() {
        const nameKeyword = document
          .getElementById("ruleNameInput")
          .value.toLowerCase();
        const statusFilter = document.getElementById("statusFilter").value;
        const levelFilter = document.getElementById("levelFilter").value;

        const filtered = ruleData.filter((rule) => {
          const matchName =
            !nameKeyword || rule.name.toLowerCase().includes(nameKeyword);
          const matchStatus = !statusFilter || rule.status === statusFilter;
          const matchLevel = !levelFilter || rule.level === levelFilter;
          return matchName && matchStatus && matchLevel;
        });

        renderTable(filtered);
      }

      function resetFilters() {
        document.getElementById("ruleNameInput").value = "";
        document.getElementById("statusFilter").value = "";
        document.getElementById("levelFilter").value = "";
        renderTable(ruleData);
      }

      function openModal(mode, rule = null) {
        const modal = document.getElementById("ruleModal");
        const modalTitle = document.getElementById("modalTitle");

        if (mode === "add") {
          modalTitle.textContent = "新增规则";
          currentEditId = null;
          document.getElementById("ruleForm").reset();
        } else {
          modalTitle.textContent = "编辑规则";
          currentEditId = rule.id;
          document.getElementById("ruleName").value = rule.name;
          document.getElementById("alertType").value = rule.type;
          document.getElementById("alertLevel").value = rule.level;
          document.getElementById("targetObject").value = rule.target;
          document.getElementById("threshold").value = "";
          document.getElementById("triggerCondition").value = rule.condition;
          document.getElementById("disposalMethod").value = "remind";
          document.getElementById("ruleStatus").value = rule.status;
          document.getElementById("remark").value = "";
        }

        modal.classList.add("show");
      }

      function closeModal() {
        const modal = document.getElementById("ruleModal");
        modal.classList.remove("show");
        document.getElementById("ruleForm").reset();
        currentEditId = null;
      }

      function saveRule() {
        const name = document.getElementById("ruleName").value;
        const alertType = document.getElementById("alertType").value;

        if (!name || !alertType) {
          alert("请填写必填项！");
          return;
        }

        const typeMap = {
          behavior: "行为预警",
          track: "轨迹预警",
          area: "区域预警",
        };
        const levelMap = { high: "高危", medium: "中危", low: "低危" };
        const targetMap = {
          focus: "重点关注人员",
          foreign: "外籍人员",
          blacklist: "黑名单人员",
        };

        if (currentEditId) {
          const index = ruleData.findIndex((r) => r.id === currentEditId);
          if (index !== -1) {
            ruleData[index] = {
              ...ruleData[index],
              name,
              type: alertType,
              typeName: typeMap[alertType],
              level: document.getElementById("alertLevel").value,
              levelName: levelMap[document.getElementById("alertLevel").value],
              target: document.getElementById("targetObject").value,
              targetName:
                targetMap[document.getElementById("targetObject").value],
              condition: document.getElementById("triggerCondition").value,
              status: document.getElementById("ruleStatus").value,
            };
          }
        } else {
          const newId = "WR" + String(ruleData.length + 1).padStart(3, "0");
          ruleData.push({
            id: newId,
            name,
            type: alertType,
            typeName: typeMap[alertType],
            condition: document.getElementById("triggerCondition").value,
            level: document.getElementById("alertLevel").value,
            levelName: levelMap[document.getElementById("alertLevel").value],
            target: document.getElementById("targetObject").value,
            targetName:
              targetMap[document.getElementById("targetObject").value],
            status: document.getElementById("ruleStatus").value,
            createTime: new Date().toISOString().slice(0, 16).replace("T", " "),
          });
        }

        renderTable(ruleData);
        closeModal();
        alert(currentEditId ? "规则更新成功！" : "规则新增成功！");
      }

      function viewRule(id) {
        const rule = ruleData.find((r) => r.id === id);
        if (rule) {
          alert(
            `规则详情：\n\n规则编号：${rule.id}\n规则名称：${rule.name}\n预警类型：${rule.typeName}\n预警等级：${rule.levelName}\n适用对象：${rule.targetName}\n触发条件：${rule.condition}\n状态：${rule.status === "enabled" ? "启用" : "停用"}\n创建时间：${rule.createTime}`,
          );
        }
      }

      function editRule(id) {
        const rule = ruleData.find((r) => r.id === id);
        if (rule) {
          openModal("edit", rule);
        }
      }

      function toggleStatus(id) {
        const rule = ruleData.find((r) => r.id === id);
        if (rule) {
          rule.status = rule.status === "enabled" ? "disabled" : "enabled";
          renderTable(ruleData);
          alert(`规则已${rule.status === "enabled" ? "启用" : "停用"}！`);
        }
      }

      function deleteRule(id) {
        if (confirm("确定要删除该规则吗？")) {
          const index = ruleData.findIndex((r) => r.id === id);
          if (index !== -1) {
            ruleData.splice(index, 1);
            renderTable(ruleData);
            alert("规则删除成功！");
          }
        }
      }

      document.querySelectorAll(".menu-section").forEach((section) => {
        const trigger = section.querySelector(".menu-trigger");
        if (trigger) {
          trigger.addEventListener("click", () => {
            section.classList.toggle("open");
          });
        }
      });

      document.getElementById("ruleModal").addEventListener("click", (e) => {
        if (e.target.classList.contains("modal-overlay")) {
          closeModal();
        }
      });

      renderTable(ruleData);
    </script>
    <script src="shell_shared.js"></script>
    <script src="header_index_standard.js"></script>
  </body>
</html>

